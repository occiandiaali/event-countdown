<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Login - Countdown Mirror</title>
    <link rel="stylesheet" href="/css/styles.css" />
    <script src="https://unpkg.com/htmx.org@1.9.12"></script>
  </head>
  <body>
    <div class="container" style="max-width: 400px; margin-top: 100px">
      <h2>Welcome Back</h2>
      <form hx-post="/auth/login" hx-target="#error-out">
        <input type="email" name="email" placeholder="Email Address" required />
        <input
          type="password"
          name="password"
          placeholder="Password"
          required
        />
        <button type="submit">Authorize Session</button>
      </form>
      <div id="error-out" style="margin-top: 10px"></div>
      <p style="text-align: center; font-size: 0.9rem">
        <a href="/register" style="color: var(--accent)"
          >Create an account instead</a
        >
      </p>
    </div>
  </body>
</html>
