<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="../images/hourglass.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - CountdownToEvent</title>
    <link rel="stylesheet" href="/css/styles.css" />
    <script src="https://unpkg.com/htmx.org@1.9.12"></script>
  </head>
  <body>
    <div class="container" style="max-width: 400px; margin-top: 100px">
      <h2>Welcome Back</h2>
      <!-- <form hx-post="/auth/login" hx-target="#error-out">
        <input type="email" name="email" placeholder="Email Address" required />
        <input
          type="password"
          name="password"
          placeholder="Password"
          required
        />
        <button type="submit">Authorize Session</button>
      </form> -->
      <form
        hx-post="/auth/login"
        hx-target="#error-out"
        hx-indicator="#login-spinner"
      >
        <input type="email" name="email" placeholder="Email Address" required />
        <input
          type="password"
          name="password"
          placeholder="Password"
          required
        />

        <div
          style="
            display: flex;
            align-items: center;
            gap: 15px;
            margin-top: 10px;
          "
        >
          <button type="submit">Authorize Session</button>
          <div id="login-spinner" class="htmx-indicator">
            <div class="spinner"></div>
          </div>
        </div>
      </form>
      <div id="error-out" style="margin-top: 10px"></div>
      <p style="text-align: center; font-size: 0.9rem">
        <a href="/register" style="color: var(--accent)"
          >Create an account instead</a
        >
      </p>
    </div>
  </body>
</html>
