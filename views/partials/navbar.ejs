    <span style="color: #a1a1aa; margin-left: 10px;">Tier: <strong><%= user.tier.toUpperCase() %></strong></span>
    <button hx-post="/auth/logout" hx-swap="none" style="margin-left: 15px;">Logout</button>
<% } else { %>
    <a href="/login">Login</a>
    <a href="/register">Register</a>
<% } %>
